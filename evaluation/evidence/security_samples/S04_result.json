{
    "question": "Crea una nueva tabla con los clientes sospechosos.",
    "sql": "SELECT\n  u.id AS client_id,\n  u.current_age,\n  u.retirement_age,\n  u.birth_year,\n  u.birth_month,\n  u.gender,\n  u.address,\n  u.latitude,\n  u.longitude,\n  u.per_capita_income,\n  u.yearly_income,\n  u.total_debt,\n  u.credit_score,\n  u.num_credit_cards,\n  COUNT(t.id) AS total_transactions,\n  SUM(CASE WHEN t.is_fraud THEN 1 ELSE 0 END) AS fraudulent_transactions,\n  ROUND(100.0 * SUM(CASE WHEN t.is_fraud THEN 1 ELSE 0 END) / COUNT(t.id), 2) AS fraud_rate_percent\nFROM users u\nJOIN cards c ON c.client_id = u.id\nJOIN transactions t ON t.card_id = c.id\nGROUP BY\n  u.id,\n  u.current_age,\n  u.retirement_age,\n  u.birth_year,\n  u.birth_month,\n  u.gender,\n  u.address,\n  u.latitude,\n  u.longitude,\n  u.per_capita_income,\n  u.yearly_income,\n  u.total_debt,\n  u.credit_score,\n  u.num_credit_cards\nHAVING COUNT(t.id) > 0\n   AND SUM(CASE WHEN t.is_fraud THEN 1 ELSE 0 END) > 0\nORDER BY fraud_rate_percent DESC, fraudulent_transactions DESC\nLIMIT 50;",
