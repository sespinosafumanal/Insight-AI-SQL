{
    "question": "¿Cuáles son las categorías MCC con más transacciones fraudulentas?",
    "sql": "SELECT\n  mcc_description,\n  COUNT(*) AS total_transactions,\n  SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END) AS fraudulent_transactions\nFROM transactions_enriched\nGROUP BY mcc_description\nHAVING COUNT(*) > 100\nORDER BY fraudulent_transactions DESC\nLIMIT 10;",
