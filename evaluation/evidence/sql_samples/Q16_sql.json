{
    "question": "¿Cuál es el importe medio de las transacciones fraudulentas frente a las no fraudulentas?",
    "sql": "SELECT\n  CASE WHEN is_fraud THEN 'fraudulentas' ELSE 'no fraudulentas' END AS tipo_transaccion,\n  AVG(amount) AS importe_medio\nFROM transactions\nGROUP BY is_fraud\nORDER BY tipo_transaccion;",
