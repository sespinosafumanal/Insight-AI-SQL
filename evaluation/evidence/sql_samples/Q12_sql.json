{
    "question": "¿Qué categorías de comercio tienen mayor importe total transaccionado?",
    "sql": "SELECT\n  COALESCE(te.mcc_description, mc.description) AS mcc_description,\n  SUM(t.amount) AS total_amount_transacted\nFROM transactions t\nLEFT JOIN transactions_enriched te\n  ON t.id = te.id\nLEFT JOIN mcc_codes mc\n  ON t.mcc = mc.mcc\nGROUP BY COALESCE(te.mcc_description, mc.description)\nORDER BY total_amount_transacted DESC\nLIMIT 50;",
    "safe": true,
