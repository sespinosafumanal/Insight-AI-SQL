{
    "question": "¿Qué porcentaje de transacciones son fraudulentas?",
    "documents": [
        {
            "id": "query-example-auto-20260518-000001",
            "doc_type": "query_example",
            "title": "Consulta validada: volumen total de transacciones y fraude",
            "content": "Pregunta del usuario: ¿Cuál es el volumen total de transacciones y qué porcentaje son fraudulentas? SQL validada: SELECT COUNT(*) AS total_transactions, SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END) AS fraudulent_transactions, ROUND(100.0 * SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END) / COUNT(*), 2) AS fraud_rate_percent FROM transactions;",
            "table_name": "transactions",
            "column_name": null,
            "source_system": "postgresql_wsl_fraud_db",
            "sql_dialect": "postgresql",
            "tags": [
