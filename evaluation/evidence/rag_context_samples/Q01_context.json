        {
            "id": "query-example-auto-20260518-000005",
            "doc_type": "query_example",
            "title": "Consulta validada: ciudades con más transacciones fraudulentas",
            "content": "Pregunta del usuario: ¿Qué ciudades concentran más transacciones fraudulentas? SQL validada: SELECT merchant_city, merchant_state, COUNT(*) AS total_transactions, SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END) AS fraudulent_transactions, ROUND(100.0 * SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END) / COUNT(*), 2) AS fraud_rate_percent FROM transactions WHERE merchant_city IS NOT NULL GROUP BY merchant_city, merchant_state HAVING COUNT(*) > 50 ORDER BY fraudulent_transactions DESC LIMIT 10;",
            "table_name": "transactions",
            "column_name": null,
            "source_system": "postgresql_wsl_fraud_db",
