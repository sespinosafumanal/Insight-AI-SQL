        {
            "id": "query-example-admin-b336ece4-43df-4244-a383-eb4a8dceaac3",
            "doc_type": "query_example",
            "title": "Consulta validada: ¿Cuál es el coste promedio por transacción agrupado por rangos de edad?",
            "content": "Pregunta del usuario: ¿Cuál es el coste promedio por transacción agrupado por rangos de edad? SQL validada: SELECT\n  CASE\n    WHEN u.current_age < 18 THEN '0-17'\n    WHEN u.current_age BETWEEN 18 AND 24 THEN '18-24'\n    WHEN u.current_age BETWEEN 25 AND 34 THEN '25-34'\n    WHEN u.current_age BETWEEN 35 AND 44 THEN '35-44'\n    WHEN u.current_age BETWEEN 45 AND 54 THEN '45-54'\n    WHEN u.current_age BETWEEN 55 AND 64 THEN '55-64'\n    ELSE '65+'\n  END AS age_range,\n  ROUND(AVG(t.amount), 2) AS average_transaction_cost,\n  COUNT(*) AS total_transactions\nFROM transactions t\nJOIN users u ON t.client_id = u.id\nGROUP BY 1\nORDER BY 1\nLIMIT 50;",
            "table_name": "transactions",
            "column_name": null,
            "source_system": "postgresql_wsl_fraud_db",
            "sql_dialect": "postgresql",
            "tags": [
                "query_example",
                "admin_approved",
                "executed_successfully"
            ],
            "related_tables": [
                "transactions",
                "users"
            ],
            "related_columns": [
                "u.current_age",
                "t.amount",
                "t.client_id",
                "u.id"
            ],
            "created_at": "2026-06-17T17:40:57.373Z",
            "updated_at": "2026-06-17T17:42:16.627Z",
            "score": 0.0331
        },
