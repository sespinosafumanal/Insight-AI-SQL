        {
            "id": "query-example-auto-20260518-000002",
            "doc_type": "query_example",
            "title": "Consulta validada: fraude por tipo de tarjeta",
            "content": "Pregunta del usuario: ¿Qué tipos de tarjeta tienen mayor tasa de fraude? SQL validada: SELECT c.card_type, COUNT(*) AS total_transactions, SUM(CASE WHEN t.is_fraud THEN 1 ELSE 0 END) AS fraudulent_transactions, ROUND(100.0 * SUM(CASE WHEN t.is_fraud THEN 1 ELSE 0 END) / COUNT(*), 2) AS fraud_rate_percent FROM transactions t JOIN cards c ON t.card_id = c.id GROUP BY c.card_type ORDER BY fraud_rate_percent DESC;",
            "table_name": "transactions",
            "column_name": null,
            "source_system": "postgresql_wsl_fraud_db",
