# ==============================================================================
# Insight AI-SQL MCP Server - Plantilla de Configuración (.env.example)
# Copia este archivo como ".env" en la raíz del proyecto y rellena los valores.
# NO subas el archivo ".env" al repositorio de Git (está en .gitignore).
# ==============================================================================

# ------------------------------------------------------------------------------
# Configuración de Azure AI Search (Buscador Vectorial RAG)
# ------------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://tu-servicio-search.search.windows.net
AZURE_SEARCH_INDEX_NAME=tu-indice-de-busqueda
AZURE_SEARCH_API_KEY=tu_api_key_de_azure_search

# ------------------------------------------------------------------------------
# Configuración de Azure OpenAI
# ------------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://tu-recurso-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=tu_api_key_de_azure_openai
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ------------------------------------------------------------------------------
# Configuración de Base de Datos Relacional (PostgreSQL)
# ------------------------------------------------------------------------------
# NOTA para Azure App Service Linux + Hybrid Connections:
# Si usas Hybrid Connections en Linux, no utilices direcciones IP puras (ej: 172.30.140.45).
# Usa un nombre FQDN/DNS ficticio (ej: fraud-db.local) y tradúcelo en el hosts local del HCM.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fraud_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password_de_postgres

# ------------------------------------------------------------------------------
# Configuración del Servidor y Panel de Administración
# ------------------------------------------------------------------------------
# Host en el que correrá el servidor local
SERVER_HOST=127.0.0.99

# Puerto para el Panel de Administración y MCP (se utiliza 8000 por defecto en main.py si ADMIN_PORT es 8001)
ADMIN_PORT=8000

# Clave secreta utilizada para firmar las cookies de sesión del panel de administración (HMAC SHA-256).
# Genera una clave segura aleatoria en producción (ej: python -c "import secrets; print(secrets.token_hex(32))")
ADMIN_SECRET_KEY=clave_secreta_super_segura_para_desarrollo_local

# ------------------------------------------------------------------------------
# Configuración Opcional y Rutas Locales
# ------------------------------------------------------------------------------
# Habilita o deshabilita el contexto de depuración RAG en la generación de SQL
SQL_DEBUG_CONTEXT=False

# Rutas locales para persistencia SQLite (relativas a la raíz del proyecto)
QUERY_STORE_PATH=data/query_candidates.db
ADMIN_STORE_PATH=data/admin_store.db
